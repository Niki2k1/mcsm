# Base URL of your Coolify instance (MCSM appends /api/v1).
# Example: https://coolify.example.com
COOLIFY_BASE_API_URL=

# Coolify API token (Bearer) with permission to create and start applications.
COOLIFY_API_TOKEN=

# Nuxt UI Pro license key. Required to build for production (`pnpm build`).
# Not needed for local development (`pnpm dev`).
NUXT_UI_PRO_LICENSE=
