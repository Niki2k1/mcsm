# --- Docker provisioning ---------------------------------------------------

# Path to the Docker daemon socket MCSM provisions on.
# In production, point this at a restricted docker-socket-proxy rather than the
# raw socket (see the README security note).
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Shared Docker network that Infrarust and the Minecraft containers both join,
# so Infrarust can resolve and reach each server.
DOCKER_MC_NETWORK=infrarust

# Image used for every Minecraft server container.
MC_IMAGE=itzg/minecraft-server

# --- Optional: remote Docker daemon (TCP/TLS) ------------------------------
# When DOCKER_HOST_ADDR is set it takes precedence over DOCKER_SOCKET_PATH.
# DOCKER_HOST_ADDR=
# DOCKER_PORT=2376
# DOCKER_PROTOCOL=https
# DOCKER_CA=
# DOCKER_CERT=
# DOCKER_KEY=
