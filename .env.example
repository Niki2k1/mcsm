# These override Nuxt `runtimeConfig` at runtime. Nuxt only re-applies env for
# `NUXT_`-prefixed vars whose names mirror the runtimeConfig structure — plain
# names (e.g. DOCKER_HOST_ADDR) work in dev but are ignored by the built server.
# https://nuxt.com/docs/guide/going-further/runtime-config

# --- Docker provisioning ---------------------------------------------------

# Path to the Docker daemon socket MCSM provisions on. Used when the TCP host
# below is empty. In production, point this at a restricted docker-socket-proxy
# rather than the raw socket (see the README security note).
NUXT_DOCKER_HOSTS_DEFAULT_SOCKET_PATH=/var/run/docker.sock

# Shared Docker network that Infrarust and the Minecraft containers both join,
# so Infrarust can resolve and reach each server.
NUXT_DOCKER_NETWORK=infrarust

# Image used for every Minecraft server container.
NUXT_DOCKER_IMAGE=itzg/minecraft-server

# RCON credentials for the in-app console. The RCON port is never published —
# only reachable on the shared Docker network. Change the password.
NUXT_RCON_PASSWORD=minecraft
NUXT_RCON_PORT=25575

# --- Optional: remote Docker daemon (TCP/TLS) ------------------------------
# When the host is set it takes precedence over the socket path above.
# NUXT_DOCKER_HOSTS_DEFAULT_HOST=
# NUXT_DOCKER_HOSTS_DEFAULT_PORT=2376
# NUXT_DOCKER_HOSTS_DEFAULT_PROTOCOL=https
# NUXT_DOCKER_HOSTS_DEFAULT_CA=
# NUXT_DOCKER_HOSTS_DEFAULT_CERT=
# NUXT_DOCKER_HOSTS_DEFAULT_KEY=
